@{
    ViewData["Title"] = "Pet Page";
}

<!-- Animal Details Section -->


<!-- Adoction Requirements and Chat Section -->


<!-- Featured Animals Section -->
<section class="featured-section py-5 text-highlight-darkblue">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <span class="text-highlight-blue text-uppercase small fw-bold">RECENTLY ADDED</span>
                <h2 class="h3 text-primary-darkblue mb-0">Featured Animals for Adoption</h2>
            </div>
            <a href="#" class="btn text-highlight-lightblue">View All Pets →</a>
        </div>

        <div class="row g-4">
            <!-- Cooper -->
            <div class="col-md-6 col-lg-3">
                <div class="animal-card card h-100 shadow-sm">
                    <img src="~/images/cooper.jpg" alt="Cooper's photo" class="card-img-top">
                    <div class="card-body">
                        <h3 class="h5 text-primary-darkblue mb-2">Cooper</h3>
                        <div class="animal-details small">
                            <p class="mb-1"><i class="bi bi-geo-alt"></i> Lisbon, Portugal</p>
                            <p class="mb-1"><i class="bi bi-calendar"></i> 4 months</p>
                            <p class="mb-1"><i class="bi bi-tag"></i> Dog · Golden Retriever</p>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="#" class="btn btn-secondary rounded-pill w-100 text-highlight-darkblue">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Luna -->
            <div class="col-md-6 col-lg-3">
                <div class="animal-card card h-100 shadow-sm">
                    <img src="~/images/luna.jpg" alt="Luna's photo" class="card-img-top">
                    <div class="card-body">
                        <h3 class="h5 text-primary-darkblue mb-2">Luna</h3>
                        <div class="animal-details small">
                            <p class="mb-1"><i class="bi bi-geo-alt"></i> Setúbal, Portugal</p>
                            <p class="mb-1"><i class="bi bi-calendar"></i> 2 years</p>
                            <p class="mb-1"><i class="bi bi-tag"></i> Cat · American Shorthair</p>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="#" class="btn btn-secondary rounded-pill w-100 text-highlight-darkblue">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Rio -->
            <div class="col-md-6 col-lg-3">
                <div class="animal-card card h-100 shadow-sm">
                    <img src="~/images/rio.jpg" alt="Rio's photo" class="card-img-top">
                    <div class="card-body">
                        <h3 class="h5 text-primary-darkblue mb-2">Rio</h3>
                        <div class="animal-details small">
                            <p class="mb-1"><i class="bi bi-geo-alt"></i> Leiria, Portugal</p>
                            <p class="mb-1"><i class="bi bi-calendar"></i> 1 Year</p>
                            <p class="mb-1"><i class="bi bi-tag"></i> Bird · Parrot · Macaw</p>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="#" class="btn btn-secondary rounded-pill w-100 text-highlight-darkblue">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Shadow -->
            <div class="col-md-6 col-lg-3">
                <div class="animal-card card h-100 shadow-sm">
                    <img src="~/images/shadow.jpg" alt="Shadow's photo" class="card-img-top">
                    <div class="card-body">
                        <h3 class="h5 text-primary-darkblue mb-2">Shadow</h3>
                        <div class="animal-details small">
                            <p class="mb-1"><i class="bi bi-geo-alt"></i> Algarve, Portugal</p>
                            <p class="mb-1"><i class="bi bi-calendar"></i> 5 Years</p>
                            <p class="mb-1"><i class="bi bi-tag"></i> Dog · Mutt</p>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="#" class="btn btn-secondary rounded-pill w-100 text-highlight-darkblue">View Details</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

